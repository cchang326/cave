{
  "entities": {
    "GameLog": {
      "title": "Game Log",
      "description": "A detailed log of a single game, including the final score and game state.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The unique ID of the player." },
        "gameId": { "type": "string", "description": "The unique ID of the game session." },
        "score": { "type": "integer", "description": "The final score achieved." },
        "gameState": { "type": "object", "description": "The final state of the game." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the game was completed." },
        "cheatsUsed": { "type": "boolean", "description": "Whether the player used any cheats during the game." }
      },
      "required": ["userId", "score", "gameState", "timestamp", "cheatsUsed"]
    },
    "GlobalStats": {
      "title": "Global Stats",
      "description": "Aggregated statistics for the application.",
      "type": "object",
      "properties": {
        "visits": { "type": "integer", "description": "Total number of app visits." },
        "gamesFinished": { "type": "integer", "description": "Total number of games completed." }
      }
    }
  },
  "firestore": {
    "/game_logs/{logId}": {
      "schema": "GameLog",
      "description": "Personal game history for users."
    },
    "/stats/{statId}": {
      "schema": "GlobalStats",
      "description": "Global application statistics."
    }
  }
}
