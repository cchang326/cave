rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "chengchang@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidGameLog(data) {
      return data.keys().hasAll(['userId', 'gameId', 'score', 'gameState', 'timestamp']) &&
             data.userId is string &&
             data.gameId is string &&
             data.score is int &&
             data.gameState is map &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /game_logs/{logId} {
      // Only the owner of the game log or an admin can read it.
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Only the authenticated user can create their own game logs.
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidGameLog(request.resource.data);
      
      // Only admins can update or delete game logs.
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
                              (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || isAdmin());
    }
  }
}
