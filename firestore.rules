rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidGameLog(data) {
      return data.keys().hasAll(['userId', 'gameId', 'score', 'gameState', 'timestamp', 'cheatsUsed']) &&
             data.userId is string &&
             data.gameId is string &&
             data.score is int &&
             data.gameState is map &&
             data.timestamp is timestamp &&
             data.cheatsUsed is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /game_logs/{logId} {
      // Only the owner of the game log or an admin can read it.
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // Only the authenticated user can create their own game logs.
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidGameLog(request.resource.data);
      
      // Users can update or delete their own game logs (e.g., pruning top 10)
      // but only if they remain the owner and the data is valid.
      allow update, delete: if isOwner(resource.data.userId) && 
                      (request.method == 'DELETE' || (
                        request.resource.data.userId == request.auth.uid &&
                        isValidGameLog(request.resource.data)
                      )) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && 
                              (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) || isAdmin());

      match /gameSaves/{slotId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /stats/{statId} {
      // Anyone can read global stats
      allow read: if true;
      
      // Only admins can create or delete stats documents
      allow create, delete: if isAdmin();
      
      // Anyone can increment the stats, but only by 1 at a time and only these specific fields
      allow update: if (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visits', 'gamesFinished'])) &&
                       (
                         (request.resource.data.visits == resource.data.visits + 1 && request.resource.data.gamesFinished == resource.data.gamesFinished) ||
                         (request.resource.data.gamesFinished == resource.data.gamesFinished + 1 && request.resource.data.visits == resource.data.visits) ||
                         (request.resource.data.visits == resource.data.visits + 1 && request.resource.data.gamesFinished == resource.data.gamesFinished + 1)
                       );
    }
  }
}
